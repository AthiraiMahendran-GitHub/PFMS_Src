@page "/loans"
@using PersonalFinanceManager.Data
@using PersonalFinanceManager.Services
@inject LoanService LoanService
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Loans</PageTitle>

<div class="card-header-gradient">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenIcon Icon="swap_horiz" Style="font-size: 2rem;" />
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0; color: white;">Loans & Lending</RadzenText>
        </RadzenStack>
        <RadzenButton Icon="add_circle" Text="Add Loan" ButtonStyle="ButtonStyle.Light" Click="@OpenAddDialog" />
    </RadzenStack>
</div>

<RadzenRow Gap="1rem" class="rz-mt-4">
    <RadzenColumn Size="12" SizeMD="6">
        <RadzenCard Style="background: linear-gradient(135deg, #f44336 0%, #e91e63 100%); color: white;">
            <RadzenStack Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.Caption">Money Lent (Given)</RadzenText>
                <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">₹@totalLent.ToString("N2")</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@lendingCount active loans</RadzenText>
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeMD="6">
        <RadzenCard Style="background: linear-gradient(135deg, #ff9800 0%, #ff5722 100%); color: white;">
            <RadzenStack Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.Caption">Money Borrowed (Taken)</RadzenText>
                <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">₹@totalBorrowed.ToString("N2")</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@borrowingCount active loans</RadzenText>
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

<RadzenTabs class="rz-mt-4">
    <Tabs>
        <RadzenTabsItem Text="Lending (Money Given)">
            <RadzenCard class="rz-mt-2">
                <RadzenDataGrid Data="@lendingLoans" TItem="LoanTransaction" AllowSorting="true" AllowPaging="true" PageSize="10">
                    <Columns>
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="PersonName" Title="Person" />
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="Amount" Title="Amount" Width="120px">
                            <Template Context="loan">
                                <RadzenText Style="font-weight: 600;">₹@loan.Amount.ToString("N2")</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="AmountPaid" Title="Paid" Width="120px">
                            <Template Context="loan">
                                <RadzenText Style="color: #4caf50;">₹@loan.AmountPaid.ToString("N2")</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="RemainingAmount" Title="Remaining" Width="120px">
                            <Template Context="loan">
                                <RadzenText Style="color: #f44336; font-weight: 600;">₹@loan.RemainingAmount.ToString("N2")</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="Status" Title="Status" Width="120px">
                            <Template Context="loan">
                                <RadzenBadge BadgeStyle="@GetStatusBadgeStyle(loan.Status)" Text="@loan.Status.ToString()" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="Date" Title="Date" Width="120px">
                            <Template Context="loan">
                                @loan.Date.ToString("dd MMM yyyy")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LoanTransaction" Title="Actions" Width="180px" Sortable="false">
                            <Template Context="loan">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                    <RadzenButton Icon="payment" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Success" 
                                                  Click="@(() => AddPayment(loan))" Text="Payment" />
                                    <RadzenButton Icon="delete" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Danger" 
                                                  Click="@(() => DeleteLoan(loan.Id))" />
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        </RadzenTabsItem>
        
        <RadzenTabsItem Text="Borrowing (Money Taken)">
            <RadzenCard class="rz-mt-2">
                <RadzenDataGrid Data="@borrowingLoans" TItem="LoanTransaction" AllowSorting="true" AllowPaging="true" PageSize="10">
                    <Columns>
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="PersonName" Title="Person" />
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="Amount" Title="Amount" Width="120px">
                            <Template Context="loan">
                                <RadzenText Style="font-weight: 600;">₹@loan.Amount.ToString("N2")</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="AmountPaid" Title="Paid" Width="120px">
                            <Template Context="loan">
                                <RadzenText Style="color: #4caf50;">₹@loan.AmountPaid.ToString("N2")</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="RemainingAmount" Title="Remaining" Width="120px">
                            <Template Context="loan">
                                <RadzenText Style="color: #f44336; font-weight: 600;">₹@loan.RemainingAmount.ToString("N2")</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="Status" Title="Status" Width="120px">
                            <Template Context="loan">
                                <RadzenBadge BadgeStyle="@GetStatusBadgeStyle(loan.Status)" Text="@loan.Status.ToString()" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LoanTransaction" Property="Date" Title="Date" Width="120px">
                            <Template Context="loan">
                                @loan.Date.ToString("dd MMM yyyy")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LoanTransaction" Title="Actions" Width="180px" Sortable="false">
                            <Template Context="loan">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                    <RadzenButton Icon="payment" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Success" 
                                                  Click="@(() => AddPayment(loan))" Text="Payment" />
                                    <RadzenButton Icon="delete" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Danger" 
                                                  Click="@(() => DeleteLoan(loan.Id))" />
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

@code {
    private List<LoanTransaction> lendingLoans = new();
    private List<LoanTransaction> borrowingLoans = new();
    private decimal totalLent;
    private decimal totalBorrowed;
    private int lendingCount;
    private int borrowingCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadLoans();
    }

    private async Task LoadLoans()
    {
        lendingLoans = await LoanService.GetLendingLoansAsync();
        borrowingLoans = await LoanService.GetBorrowingLoansAsync();
        totalLent = await LoanService.GetTotalLentAsync();
        totalBorrowed = await LoanService.GetTotalBorrowedAsync();
        lendingCount = lendingLoans.Count(l => l.Status == LoanStatus.Active || l.Status == LoanStatus.PartiallyPaid);
        borrowingCount = borrowingLoans.Count(l => l.Status == LoanStatus.Active || l.Status == LoanStatus.PartiallyPaid);
    }

    private async Task OpenAddDialog()
    {
        var result = await DialogService.OpenAsync<LoanDialog>("Add Loan",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "600px" });

        if (result != null)
        {
            await LoadLoans();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Loan added successfully");
        }
    }

    private async Task AddPayment(LoanTransaction loan)
    {
        var result = await DialogService.OpenAsync<PaymentDialog>("Add Payment",
            new Dictionary<string, object> { { "LoanId", loan.Id } },
            new DialogOptions { Width = "500px" });

        if (result != null)
        {
            await LoadLoans();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Payment recorded successfully");
        }
    }

    private async Task DeleteLoan(int id)
    {
        var confirm = await DialogService.Confirm("Are you sure you want to delete this loan?", "Delete Loan",
            new ConfirmOptions { OkButtonText = "Yes", CancelButtonText = "No" });

        if (confirm == true)
        {
            await LoanService.DeleteLoanAsync(id);
            await LoadLoans();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Loan deleted successfully");
        }
    }

    private BadgeStyle GetStatusBadgeStyle(LoanStatus status) => status switch
    {
        LoanStatus.Active => BadgeStyle.Warning,
        LoanStatus.PartiallyPaid => BadgeStyle.Info,
        LoanStatus.FullyPaid => BadgeStyle.Success,
        LoanStatus.Overdue => BadgeStyle.Danger,
        _ => BadgeStyle.Secondary
    };
}
