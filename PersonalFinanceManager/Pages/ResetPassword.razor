@page "/reset-password"
@layout EmptyLayout
@inject NavigationManager NavigationManager
@inject Radzen.NotificationService NotificationService

<PageTitle>Reset Password - Personal Finance Manager</PageTitle>

<div class="reset-password-container">
    <RadzenCard class="reset-password-card">
        <RadzenStack Gap="2rem">
            <!-- Logo/Header -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="lock_open" Style="font-size: 4rem; color: var(--rz-primary);" />
                <RadzenText TextStyle="TextStyle.H3" Style="margin: 0;">Reset Password</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); text-align: center;">
                    Enter your new password below
                </RadzenText>
            </RadzenStack>

            @if (!passwordReset)
            {
                <!-- Reset Password Form -->
                <EditForm Model="@resetPasswordModel" OnValidSubmit="@HandleResetPassword">
                    <DataAnnotationsValidator />
                    
                    <RadzenStack Gap="1.5rem">
                        <RadzenFormField Text="New Password" Variant="Variant.Outlined">
                            <RadzenPassword @bind-Value="resetPasswordModel.NewPassword" 
                                            Placeholder="Enter new password" 
                                            Style="width: 100%;" />
                        </RadzenFormField>

                        <RadzenFormField Text="Confirm New Password" Variant="Variant.Outlined">
                            <RadzenPassword @bind-Value="resetPasswordModel.ConfirmPassword" 
                                            Placeholder="Confirm new password" 
                                            Style="width: 100%;" />
                        </RadzenFormField>

                        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter">
                            <RadzenText TextStyle="TextStyle.Caption">
                                Password must be at least 6 characters long
                            </RadzenText>
                        </RadzenAlert>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter">
                                @errorMessage
                            </RadzenAlert>
                        }

                        <RadzenButton Text="Reset Password" 
                                      ButtonType="ButtonType.Submit" 
                                      ButtonStyle="ButtonStyle.Primary" 
                                      Icon="check_circle"
                                      Size="ButtonSize.Large"
                                      Style="width: 100%;" />

                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" Gap="0.5rem">
                            <RadzenLink Path="/login" Text="Back to Login" Icon="arrow_back" Style="font-weight: 600;" />
                        </RadzenStack>
                    </RadzenStack>
                </EditForm>
            }
            else
            {
                <!-- Success Message -->
                <RadzenStack Gap="1.5rem" AlignItems="AlignItems.Center">
                    <RadzenAlert AlertStyle="AlertStyle.Success" Variant="Variant.Flat" Shade="Shade.Lighter" Style="width: 100%;">
                        <RadzenStack Gap="0.5rem" AlignItems="AlignItems.Center">
                            <RadzenIcon Icon="check_circle" Style="font-size: 3rem; color: var(--rz-success);" />
                            <RadzenText TextStyle="TextStyle.H6">Password Reset Successful!</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="text-align: center;">
                                Your password has been reset successfully. You can now login with your new password.
                            </RadzenText>
                        </RadzenStack>
                    </RadzenAlert>

                    <RadzenButton Text="Go to Login" 
                                  Icon="login"
                                  ButtonStyle="ButtonStyle.Primary" 
                                  Click="@(() => NavigationManager.NavigateTo("/login"))"
                                  Size="ButtonSize.Large" />
                </RadzenStack>
            }
        </RadzenStack>
    </RadzenCard>
</div>

<style>
    .reset-password-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
    }

    .reset-password-card {
        width: 100%;
        max-width: 450px;
        padding: 3rem 2rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    @@media (max-width: 576px) {
        .reset-password-card {
            padding: 2rem 1.5rem;
        }
    }
</style>

@code {
    private ResetPasswordModel resetPasswordModel = new();
    private string errorMessage = string.Empty;
    private bool passwordReset = false;

    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    protected override void OnInitialized()
    {
        // Check if token is provided
        if (string.IsNullOrEmpty(Token))
        {
            errorMessage = "Invalid or expired reset link. Please request a new password reset.";
        }
    }

    private void HandleResetPassword()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(resetPasswordModel.NewPassword))
        {
            errorMessage = "Please enter a new password.";
            return;
        }

        if (resetPasswordModel.NewPassword.Length < 6)
        {
            errorMessage = "Password must be at least 6 characters long.";
            return;
        }

        if (resetPasswordModel.NewPassword != resetPasswordModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        // TODO: Implement actual password reset logic
        // For now, just show success message
        passwordReset = true;
        NotificationService.Notify(Radzen.NotificationSeverity.Success, "Success", "Password reset successfully!");
    }

    public class ResetPasswordModel
    {
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
