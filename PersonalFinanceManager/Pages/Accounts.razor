@page "/accounts"
@using PersonalFinanceManager.Data
@using PersonalFinanceManager.Services
@inject AccountService AccountService
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Accounts</PageTitle>

<div class="card-header-gradient">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenIcon Icon="account_balance" Style="font-size: 2rem;" />
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0; color: white;">Accounts</RadzenText>
        </RadzenStack>
        <RadzenButton Icon="add_circle" Text="Add Account" ButtonStyle="ButtonStyle.Light" Click="@OpenAddDialog" />
    </RadzenStack>
</div>

<RadzenRow Gap="1rem" class="rz-mt-4">
    @foreach (var account in accounts)
    {
        <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
            <RadzenCard class="dashboard-card" Style="height: 100%;">
                <RadzenStack Gap="1rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenIcon Icon="@GetAccountIcon(account.Type)" Style="@GetAccountIconStyle(account.Type)" />
                            <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">@account.Name</RadzenText>
                        </RadzenStack>
                        <RadzenBadge BadgeStyle="@(account.IsActive ? BadgeStyle.Success : BadgeStyle.Secondary)" 
                                     Text="@(account.IsActive ? "Active" : "Inactive")" />
                    </RadzenStack>
                    
                    <RadzenText TextStyle="TextStyle.H5" Style="@GetBalanceColor(account.Balance)">
                        ₹@account.Balance.ToString("N2")
                    </RadzenText>
                    
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: #666;">
                        @account.Type.ToString()
                        @if (!string.IsNullOrEmpty(account.AccountNumber))
                        {
                            <text> • @account.AccountNumber</text>
                        }
                    </RadzenText>
                    
                    @if (!string.IsNullOrEmpty(account.Description))
                    {
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: #888;">@account.Description</RadzenText>
                    }
                    
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-4">
                        <RadzenButton Icon="edit" Text="Edit" Size="ButtonSize.Small" 
                                      ButtonStyle="ButtonStyle.Primary" Click="@(() => OpenEditDialog(account))" />
                        <RadzenButton Icon="delete" Text="Delete" Size="ButtonSize.Small" 
                                      ButtonStyle="ButtonStyle.Danger" Click="@(() => DeleteAccount(account.Id))" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    }
</RadzenRow>

@if (!accounts.Any())
{
    <RadzenCard class="rz-mt-4" Style="text-align: center; padding: 3rem;">
        <RadzenIcon Icon="account_balance_wallet" Style="font-size: 4rem; color: #ccc;" />
        <RadzenText TextStyle="TextStyle.H6" Style="color: #999; margin-top: 1rem;">No accounts yet</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Style="color: #bbb;">Click "Add Account" to create your first account</RadzenText>
    </RadzenCard>
}

@code {
    private List<Account> accounts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAccounts();
    }

    private async Task LoadAccounts()
    {
        accounts = await AccountService.GetAllAccountsAsync();
    }

    private async Task OpenAddDialog()
    {
        var result = await DialogService.OpenAsync<AccountDialog>("Add Account",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "500px" });

        if (result != null)
        {
            await LoadAccounts();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Account added successfully");
        }
    }

    private async Task OpenEditDialog(Account account)
    {
        var result = await DialogService.OpenAsync<AccountDialog>("Edit Account",
            new Dictionary<string, object> { { "AccountId", account.Id } },
            new DialogOptions { Width = "500px" });

        if (result != null)
        {
            await LoadAccounts();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Account updated successfully");
        }
    }

    private async Task DeleteAccount(int id)
    {
        var confirm = await DialogService.Confirm("Are you sure you want to delete this account?", "Delete Account",
            new ConfirmOptions { OkButtonText = "Yes", CancelButtonText = "No" });

        if (confirm == true)
        {
            await AccountService.DeleteAccountAsync(id);
            await LoadAccounts();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Account deleted successfully");
        }
    }

    private string GetAccountIcon(AccountType type) => type switch
    {
        AccountType.Cash => "payments",
        AccountType.Bank => "account_balance",
        AccountType.CreditCard => "credit_card",
        AccountType.Wallet => "account_balance_wallet",
        _ => "account_balance"
    };

    private string GetAccountIconStyle(AccountType type)
    {
        var color = type switch
        {
            AccountType.Cash => "#4caf50",
            AccountType.Bank => "#2196f3",
            AccountType.CreditCard => "#ff9800",
            AccountType.Wallet => "#9c27b0",
            _ => "#666"
        };
        return $"font-size: 2rem; color: {color};";
    }

    private string GetBalanceColor(decimal balance)
    {
        var color = balance >= 0 ? "#4caf50" : "#f44336";
        return $"margin: 0; font-weight: bold; color: {color};";
    }
}
