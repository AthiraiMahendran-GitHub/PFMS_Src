@page "/categories"
@using PersonalFinanceManager.Data
@using PersonalFinanceManager.Services
@inject CategoryService CategoryService
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Categories</PageTitle>

<div class="card-header-gradient">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenIcon Icon="category" Style="font-size: 2rem;" />
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0; color: white;">Expense Categories</RadzenText>
        </RadzenStack>
        <RadzenButton Icon="add_circle" Text="Add Category" ButtonStyle="ButtonStyle.Light" Click="@OpenAddDialog" />
    </RadzenStack>
</div>

<RadzenRow Gap="1rem" class="rz-mt-4">
    @foreach (var category in categories.Where(c => c.ParentCategoryId == null))
    {
        <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
            <RadzenCard class="dashboard-card" Style="height: 100%;">
                <RadzenStack Gap="1rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        @if (!string.IsNullOrEmpty(category.Icon))
                        {
                            <RadzenIcon Icon="@category.Icon" Style="@($"font-size: 2rem; color: {category.Color ?? "#666"};")" />
                        }
                        <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">@category.Name</RadzenText>
                    </RadzenStack>
                    
                    @if (!string.IsNullOrEmpty(category.Description))
                    {
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: #888;">@category.Description</RadzenText>
                    }
                    
                    @if (category.SubCategories.Any())
                    {
                        <RadzenStack Gap="0.25rem">
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: #666; font-weight: 600;">Subcategories:</RadzenText>
                            @foreach (var sub in category.SubCategories)
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@sub.Name" Style="margin-right: 0.25rem;" />
                            }
                        </RadzenStack>
                    }
                    
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-4">
                        <RadzenButton Icon="add" Text="Add Sub" Size="ButtonSize.Small" 
                                      ButtonStyle="ButtonStyle.Info" Click="@(() => OpenAddSubDialog(category.Id))" />
                        <RadzenButton Icon="edit" Text="Edit" Size="ButtonSize.Small" 
                                      ButtonStyle="ButtonStyle.Primary" Click="@(() => OpenEditDialog(category))" />
                        <RadzenButton Icon="delete" Text="Delete" Size="ButtonSize.Small" 
                                      ButtonStyle="ButtonStyle.Danger" Click="@(() => DeleteCategory(category.Id))" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    }
</RadzenRow>

@if (!categories.Any())
{
    <RadzenCard class="rz-mt-4" Style="text-align: center; padding: 3rem;">
        <RadzenIcon Icon="category" Style="font-size: 4rem; color: #ccc;" />
        <RadzenText TextStyle="TextStyle.H6" Style="color: #999; margin-top: 1rem;">No categories yet</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Style="color: #bbb;">Click "Add Category" to create your first category</RadzenText>
    </RadzenCard>
}

@code {
    private List<ExpenseCategory> categories = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        categories = await CategoryService.GetAllCategoriesAsync();
    }

    private async Task OpenAddDialog()
    {
        var result = await DialogService.OpenAsync<CategoryDialog>("Add Category",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "500px" });

        if (result != null)
        {
            await LoadCategories();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Category added successfully");
        }
    }

    private async Task OpenAddSubDialog(int parentId)
    {
        var result = await DialogService.OpenAsync<CategoryDialog>("Add Subcategory",
            new Dictionary<string, object> { { "ParentCategoryId", parentId } },
            new DialogOptions { Width = "500px" });

        if (result != null)
        {
            await LoadCategories();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Subcategory added successfully");
        }
    }

    private async Task OpenEditDialog(ExpenseCategory category)
    {
        var result = await DialogService.OpenAsync<CategoryDialog>("Edit Category",
            new Dictionary<string, object> { { "CategoryId", category.Id } },
            new DialogOptions { Width = "500px" });

        if (result != null)
        {
            await LoadCategories();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Category updated successfully");
        }
    }

    private async Task DeleteCategory(int id)
    {
        var confirm = await DialogService.Confirm("Are you sure you want to delete this category?", "Delete Category",
            new ConfirmOptions { OkButtonText = "Yes", CancelButtonText = "No" });

        if (confirm == true)
        {
            await CategoryService.DeleteCategoryAsync(id);
            await LoadCategories();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Category deleted successfully");
        }
    }
}
