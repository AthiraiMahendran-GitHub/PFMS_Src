@page "/forgot-password"
@layout EmptyLayout
@inject NavigationManager NavigationManager
@inject Radzen.NotificationService NotificationService

<PageTitle>Forgot Password - Personal Finance Manager</PageTitle>

<div class="forgot-password-container">
    <RadzenCard class="forgot-password-card">
        <RadzenStack Gap="2rem">
            <!-- Logo/Header -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="lock_reset" Style="font-size: 4rem; color: var(--rz-primary);" />
                <RadzenText TextStyle="TextStyle.H3" Style="margin: 0;">Forgot Password?</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); text-align: center;">
                    No worries! Enter your email and we'll send you reset instructions.
                </RadzenText>
            </RadzenStack>

            @if (!emailSent)
            {
                <!-- Forgot Password Form -->
                <EditForm Model="@forgotPasswordModel" OnValidSubmit="@HandleForgotPassword">
                    <DataAnnotationsValidator />
                    
                    <RadzenStack Gap="1.5rem">
                        <RadzenFormField Text="Email Address" Variant="Variant.Outlined">
                            <RadzenTextBox @bind-Value="forgotPasswordModel.Email" 
                                           Placeholder="Enter your registered email" 
                                           Style="width: 100%;" />
                        </RadzenFormField>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter">
                                @errorMessage
                            </RadzenAlert>
                        }

                        <RadzenButton Text="Send Reset Link" 
                                      ButtonType="ButtonType.Submit" 
                                      ButtonStyle="ButtonStyle.Primary" 
                                      Icon="send"
                                      Size="ButtonSize.Large"
                                      Style="width: 100%;" />

                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" Gap="0.5rem">
                            <RadzenLink Path="/login" Text="Back to Login" Icon="arrow_back" Style="font-weight: 600;" />
                        </RadzenStack>
                    </RadzenStack>
                </EditForm>
            }
            else
            {
                <!-- Success Message -->
                <RadzenStack Gap="1.5rem" AlignItems="AlignItems.Center">
                    <RadzenAlert AlertStyle="AlertStyle.Success" Variant="Variant.Flat" Shade="Shade.Lighter" Style="width: 100%;">
                        <RadzenStack Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.H6">Email Sent!</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2">
                                We've sent password reset instructions to <strong>@forgotPasswordModel.Email</strong>
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2">
                                Please check your inbox and follow the link to reset your password.
                            </RadzenText>
                        </RadzenStack>
                    </RadzenAlert>

                    <RadzenButton Text="Back to Login" 
                                  Icon="arrow_back"
                                  ButtonStyle="ButtonStyle.Primary" 
                                  Click="@(() => NavigationManager.NavigateTo("/login"))"
                                  Size="ButtonSize.Large" />
                </RadzenStack>
            }
        </RadzenStack>
    </RadzenCard>
</div>

<style>
    .forgot-password-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
    }

    .forgot-password-card {
        width: 100%;
        max-width: 450px;
        padding: 3rem 2rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    @@media (max-width: 576px) {
        .forgot-password-card {
            padding: 2rem 1.5rem;
        }
    }
</style>

@code {
    private ForgotPasswordModel forgotPasswordModel = new();
    private string errorMessage = string.Empty;
    private bool emailSent = false;

    private void HandleForgotPassword()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(forgotPasswordModel.Email))
        {
            errorMessage = "Please enter your email address.";
            return;
        }

        if (!forgotPasswordModel.Email.Contains("@"))
        {
            errorMessage = "Please enter a valid email address.";
            return;
        }

        // TODO: Implement actual password reset email sending
        // For now, just show success message
        emailSent = true;
        NotificationService.Notify(Radzen.NotificationSeverity.Success, "Success", "Password reset email sent!");
    }

    public class ForgotPasswordModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
